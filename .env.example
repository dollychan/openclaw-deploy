# ─── OpenClaw 连接配置 ────────────────────────────────────────────────────────
# OpenClaw Gateway 地址（同服务器使用 localhost）
OPENCLAW_BASE_URL=http://localhost:18789

# OpenClaw API 认证 Token（在 openclaw.json 的 gateway.auth.token 中配置）
OPENCLAW_TOKEN=your-openclaw-token-here

# ─── 文件系统路径（与 OpenClaw 同服务器部署）────────────────────────────────
# openclaw.json 配置文件路径
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json

# 用户 workspace 存放根目录
OPENCLAW_WORKSPACES_DIR=/root/.openclaw/workspaces

# 本项目的 templates 目录路径（可使用相对路径）
TEMPLATE_DIR=./templates

# ─── Web 服务配置 ──────────────────────────────────────────────────────────
PORT=3000
# 服务的公网地址（用于 CORS 限制）
BASE_URL=https://yourserver.com

# ─── 安全密钥（请使用 openssl rand -hex 32 生成）────────────────────────────
# 用于 HMAC 签名 visitorId，防止伪造
HMAC_SECRET=change_this_to_a_random_64_char_hex_string_generated_with_openssl

# 用于 cookie 签名
COOKIE_SECRET=change_this_to_another_random_64_char_hex_string

# ─── 限流配置 ──────────────────────────────────────────────────────────────
# 时间窗口（毫秒）
RATE_LIMIT_WINDOW_MS=60000
# 窗口内最大请求数
RATE_LIMIT_MAX_REQUESTS=20

# ─── Agent 模式 ────────────────────────────────────────────────────────────
# single: 使用固定 agent，每个访客通过独立 session 访问（简单部署，无需文件系统权限）
# multi:  每个访客动态创建专属 agent（完全隔离，需要 OPENCLAW_CONFIG_PATH 等路径配置）
AGENT_MODE=single

# single 模式下使用的 agent ID（对应 openclaw.json 中已配置的 agent）
SINGLE_AGENT_ID=main

# multi 模式专用
AGENT_ID_PREFIX=web-visitor-

# 单条消息最大字符数
MAX_INPUT_LENGTH=2000
